# ╔══════════════════════════════════════════════════════════════╗
# ║  PENTEXA — Environment Variables for Vercel Dashboard       ║
# ║  Copy each key-value pair into:                             ║
# ║  Vercel → Project → Settings → Environment Variables        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Project ──
PROJECT_NAME="Pentexa Backend API"
API_V1_STR="/api/v1"

# ── JWT Secrets (generate strong random values!) ──
SECRET_KEY="CHANGE_ME_use_openssl_rand_hex_64"
REFRESH_SECRET_KEY="CHANGE_ME_use_openssl_rand_hex_64"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL (Neon / Supabase / Railway) ──
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://user:password@your-db-host.com:5432/pentexa_db"

# ── Redis (Upstash / Railway) ──
# For Upstash use: rediss://default:your_password@your-endpoint.upstash.io:6379
REDIS_URL="rediss://default:your_password@your-redis-host:6379"

# ── CORS — Frontend URL ──
FRONTEND_URL="https://your-frontend-domain.vercel.app"

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60

# ── Login Protection ──
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
